# Qwen2.5-Coder-14B-Instruct, Q4_K_M — tuned for full-GPU 32k on an RTX 5080 (16 GB).
#
# Build:   ollama create qwen-coder-14b-vts -f Modelfile.qwen-coder
# Run:     ollama run qwen-coder-14b-vts
#
# 16 GB VRAM budget @ 32k:
#   Q4_K_M weights ~9 GB + fp16 KV @ 32k ~6 GB + compute ~1 GB = ~16 GB  -> does NOT fit cleanly.
#   So we quantize the KV cache to q8_0 (KV ~3 GB) via OLLAMA_KV_CACHE_TYPE + flash-attention.
#   Those are SERVER env vars, not Modelfile params — setup.ps1 sets them. With them on, the whole
#   model + 32k context lives on the GPU (num_gpu 999 forces every layer onto VRAM).
FROM qwen2.5-coder:14b-instruct-q4_K_M

# 32k context window.
PARAMETER num_ctx 32768

# Force ALL transformer layers onto the GPU (999 = "as many as exist"). If Ollama still reports
# partial CPU offload, free other VRAM users or drop num_ctx to 24576/16384.
PARAMETER num_gpu 999

# Deterministic-leaning decoding for tool-driving / code work.
# Qwen2.5 official sampler recommendation: top_p 0.8 / top_k 20 / repeat_penalty 1.05 — pushing these
# higher breaks code/JSON. Low temperature is what makes tool-call argument & code generation reliable.
PARAMETER temperature 0.15
PARAMETER top_p 0.8
PARAMETER top_k 20
PARAMETER repeat_penalty 1.05
# Cap a single response so a confused turn can't spew thousands of tokens.
PARAMETER num_predict 4096

# Keep the model resident so the agent loop doesn't pay reload latency between turns.
# (Also set OLLAMA_KEEP_ALIVE in setup.ps1 for the server default.)
