# deps
node_modules/

# machine-specific generated config (contains local paths) — never commit
qvts.config.json
Modelfile.generated

# org-specific secret-scan denylist (company codenames / internal symbols / paths) — NEVER commit
# (a denylist of secrets committed in plaintext would itself be the leak). See scripts/secret-scan.mjs.
.secret-patterns

# runtime / test artifacts (may contain local paths + code identifiers)
*.log
*.log.out
sse*.log
err*.log
dash*.log
ollama-serve.log*

# OMC / agent session state
.omc/
.claude/
scratchpad/

# os
Thumbs.db
.DS_Store
